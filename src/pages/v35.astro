---
// Voxel v35 — copied from v34. ONLY change: remove the glowing teal "node" dots
// from the palm. They rested visible only on the palm (every other element is
// just faces + thin white edges), so they looked inconsistent. The palm now
// builds + rests in the same clean style — no glowing nodes. Everything else
// unchanged; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v35/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v35</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; palm cleaned up (no glowing nodes), matching the other elements." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
