---
// Voxel v45 — copied from v44. ONLY change: tone down the white settle EDGES so
// colours come forward and the grid recedes. Water edges are strongly reduced
// (water-tinted + very low opacity) so the turquoise reads, not a white grid;
// solid objects keep softened-but-visible cool-white edges. Edge styling only;
// geometry/colours/animations unchanged; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v45/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v45</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; toned-down wireframe edges so colours read." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
