---
// Voxel v38 — copied from v37. ONLY change: the distant cruise ship now idles
// almost imperceptibly — a very slight, very slow vertical bob + a tiny roll, NO
// pitch (a big far liner barely moves; distant motion looks exaggerated). Slower
// and on a different phase than the longtail so they're not in sync. Clock-driven,
// paused offscreen. Only the cruise ship moves; rotation stays paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v38/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v38</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; the distant cruise ship barely bobs on the swell." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
