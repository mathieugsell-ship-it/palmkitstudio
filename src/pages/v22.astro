---
// Voxel v22 — copied from v20 (the realistic base). TWO water-only fixes:
// (1) real perspective — the sea cells shrink + tighten as they recede toward
// the back/horizon; (2) depth colour — water gets DARKER + more saturated the
// further back it goes (near = lighter/brighter). Palm, island, boat, pitons and
// the overall water shape are unchanged. No interactivity/UI; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v22/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v22</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman scene: water with depth perspective + darkening." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
