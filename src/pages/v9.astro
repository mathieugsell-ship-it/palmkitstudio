---
// Voxel v9 — copied from v8. Scenery step 6: the WHOLE scene builds itself as a
// glowing blue wireframe (island → palm → water), faces fill, then a top→bottom
// sweep crystallizes the edges to thin white. Then idle rotation.
import '../styles/global.css';
import PalmTreeHero from '../components/v9/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v9</title>
    <meta name="description" content="Palmkit Studio — the whole world draws itself, then settles to white." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
