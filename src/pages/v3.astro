---
// Voxel v3 — copied from v2. Scenery step 1: adds a voxel island/beach base
// under the palm. Palm unchanged; base recessed/transparent.
import '../styles/global.css';
import PalmTreeHero from '../components/v3/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v3</title>
    <meta name="description" content="Palmkit Studio — voxel palm v3 (island base)." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden bg-white">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html,
      body {
        margin: 0;
        padding: 0;
        background: #ffffff;
      }
    </style>
  </body>
</html>
