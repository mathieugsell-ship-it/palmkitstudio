---
// Voxel v21 — copied from v20. Only change: the water is reshaped into ONE clean
// circular DISC centred on the islet (big round pool), large enough to contain
// the distant pitons toward its back edge — instead of the islet-ring + back
// tongue. Cells still taper finer toward the back for depth. Islet, palm, boat,
// pitons unchanged. No interactivity/UI; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v21/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v21</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman lagoon: round water disc with islet, boat & distant pitons." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
