---
// Voxel v26 — copied from v24 (no coconuts). ONLY addition: a warm voxel SUN
// low on the horizon, center-left, behind the scene — balancing the pitons on
// the back-right and anchoring the dawn light (maps to Growth). Palm, island,
// water, boat, pitons, dawn all unchanged. No interactivity/UI; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v26/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v26</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn with a warm sun rising on the horizon." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
