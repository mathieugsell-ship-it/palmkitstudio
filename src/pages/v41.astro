---
// Voxel v41 — copied from v40. Two tweaks: (1) GROUP the two karst pitons close
// on the left (small stack pulled in beside the big one), sun peeking in the gap;
// (2) push the ISLAND + palm slightly BACK along the view axis (shared
// ISLAND_OFFSET) so it recedes and leaves more foreground water — the sea's outer
// edge stays anchored to origin, only the island's footprint moves. Cruise ship,
// boat, palette, water-outer, animations unchanged; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v41/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v41</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; grouped karst pitons, island pushed back for more foreground." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
