---
// Voxel v33 — copied from v32. ONLY change: rebuild the CRUISE SHIP so it reads
// as a liner, not a flat grey platform — a long hull with a dark-navy waterline
// base, THREE clearly stepped (narrowing) superstructure tiers and two coral
// funnels, near-solid and in a warm cream that pops against the turquoise water.
// Still back-left under the sun, modest + distant. Everything else unchanged;
// rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v33/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v33</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; a clearly stacked cream cruise liner back-left under the sun." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
