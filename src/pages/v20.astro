---
// Voxel v20 — copied from v19 (solid karst pitons far back on the horizon).
// Only change: the water is EXTENDED back from the islet toward the distant
// pitons, with the cells (and band) shrinking with distance — a voxel
// perspective recede — so the pitons emerge from the sea instead of floating.
// Foreground islet water + pitons unchanged. No interactivity/UI; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v20/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v20</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman bay: sea receding to distant karst pitons." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
