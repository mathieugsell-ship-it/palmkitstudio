---
// Voxel v37 — copied from v36. ONLY change: the palm FRONDS now sway in a gentle
// breeze — each frond softly fans + nods about the crown, with a per-frond phase
// offset so the wind ripples through. Very low amplitude, slow, sine-looped (a
// shimmer, not flapping); the trunk stays still. Clock-driven, paused offscreen.
// Only the fronds move; rotation stays paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v37/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v37</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; the palm fronds shimmer in a gentle breeze." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
