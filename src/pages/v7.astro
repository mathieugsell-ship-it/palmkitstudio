---
// Voxel v7 — copied from v6. Scenery step 3: gentle water ripple animation.
// Palm + island still; only the water bobs. Sunrise backdrop kept.
import '../styles/global.css';
import PalmTreeHero from '../components/v7/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v7</title>
    <meta name="description" content="Palmkit Studio — voxel islet with gentle water ripple." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
