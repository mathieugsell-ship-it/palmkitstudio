---
// Voxel v28 — copied from v27. ONLY change: reshape the ISLAND again. v27 still
// spread too far LEFT/FRONT (boat nearly on the sand). Now shrink the island on
// the left + front so the boat clearly floats with water all around it, and grow
// it instead toward the BACK / into the DEPTH (along the view axis, behind the
// palm) so it gains size in depth, not on the left. Palm stays roughly centered.
// Palm, water, boat, pitons, sun, dawn all unchanged. No interactivity; paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v28/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v28</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; island grown into the depth behind the palm, boat floating free." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
