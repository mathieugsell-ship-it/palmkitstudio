---
// Voxel v40 — copied from v39. ONLY change: recompose for balance. Left: the two
// karst pitons move to the left and spread apart, with the SUN rising in the gap
// between them (sunrise through the Phang Nga karsts) + its dawn glow follows.
// Right: the cruise ship moves to the screen-right horizon. Foreground: the
// longtail comes to centre-right. Palm/island stays the central hero. Only those
// four elements move; palette, water, animations, styles unchanged; paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v40/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v40</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; rebalanced composition, sun rising between the karst pitons." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
