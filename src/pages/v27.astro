---
// Voxel v27 — copied from v26. ONLY change: reshape the ISLAND. The v26 island
// grew too far toward the front-left and the boat ended up partly on the sand.
// Pull the island back to its original size in the boat/front sector and aim
// the growth squarely at the empty BACK-left instead. Palm, water, boat, pitons,
// sun, dawn all unchanged. No interactivity/UI; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v27/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v27</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; island reshaped to grow into the empty back-left." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
