---
// Voxel v24 — copied from v23. ONE change: the rounded back edge is now centred
// on the camera's view axis so it reads SYMMETRIC on screen — the far water
// curves evenly around BOTH the left and right of the back (v23 looked rounded
// on the right, flat on the left, because the camera views from the front-right).
// Front untouched (no cubes in front). Depth perspective + darkening kept exactly.
// No interactivity/UI; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v24/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v24</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman scene: symmetric rounded water back edge." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
