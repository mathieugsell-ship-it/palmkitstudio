---
// Voxel v29 — copied from v28. ONLY change: ADD sand to the BACK-LEFT corner of
// the island (a separate, angularly-windowed bump) so that empty water fills in
// too. The back lobe (along the view axis) is kept EXACTLY as in v28; the bump
// is zero outside its window, so the front, right, back, boat, water, pitons and
// sun are all untouched. No interactivity/UI; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v29/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v29</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; island back-left corner filled in, back lobe unchanged." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
