---
// Voxel v25 — copied from v24. ONLY addition: a small cluster of voxel coconuts
// nestled under the palm crown (maps to E-commerce). Same voxel treatment; they
// rotate with the scene. Palm, island, water, boat, pitons, dawn all unchanged.
// No interactivity/UI; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v25/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v25</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman scene with coconuts nestled under the palm crown." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
