---
// Voxel v17 — copied from v15 (the SOLID karst pitons that read as real rock).
// Only change vs v15: the two pitons are repositioned further back-right
// (behind/beside the islet), well clear of the palm. Same size/shape/colours/
// solidity. No interactivity/UI; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v17/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v17</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman scene: solid karst pitons repositioned back-right." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
