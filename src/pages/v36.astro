---
// Voxel v36 — copied from v35. ONLY change: the longtail boat now gently idles on
// the water — a soft sine pitch (bow rise/dip) + slight roll + tiny bob, low
// amplitude and slow, looping naturally. Clock-driven (framerate-independent),
// paused offscreen with the rest of the live motion; bob synced ~to the water
// ripple rhythm. Only the boat moves; rotation stays paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v36/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v36</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; the longtail boat gently rocks on the water." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
