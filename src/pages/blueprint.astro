---
// Variant B — low-poly triangulated "tech blueprint" palm. Separate page so the
// voxel version stays untouched. Full-viewport, light background.
import '../styles/global.css';
import PalmTreeMesh from '../components/palm/PalmTreeMesh.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Blueprint</title>
    <meta name="description" content="Palmkit Studio — triangulated blueprint palm." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <!-- Single 3D island; mounted client-only so it never blocks LCP. -->
      <PalmTreeMesh client:only="react" />
      <a
        href="/"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← Voxel version</a
      >
    </main>
    <style is:global>
      html,
      body {
        margin: 0;
        padding: 0;
        background: #eef2f1;
      }
    </style>
  </body>
</html>
