---
// Voxel v43 — copied from v42. ONLY change: make the WATER pop. Base colours
// pushed to Option C (near #2FD4C0, body #07A7B0, far #086E7B), near-water
// saturation lifted so the shallows stop greying out, and waterOpacity 0.7 ->
// 0.82 (less see-through so the turquoise reads vivid over the pale dawn, still
// slightly translucent). Depth-darkening + perspective taper kept. Everything
// else unchanged; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v43/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v43</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; richer, more vivid turquoise water." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
