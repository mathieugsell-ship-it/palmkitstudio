---
// Voxel v44 — copied from v43. ONLY change: rebuild the CRUISE SHIP so it reads
// as a liner, not a flat platform — taller hull with a clear dark base band, and
// THREE distinctly stepped (shorter+narrower) superstructure tiers + taller
// funnels, fully opaque (shipOpacity 1.0) so it stands out from the vivid water.
// Same back-right horizon placement, cream/navy/coral colours. Everything else
// unchanged; rotation paused.
import '../styles/global.css';
import PalmTreeHero from '../components/v44/PalmTreeHero.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Voxel v44</title>
    <meta name="description" content="Palmkit Studio — voxel Andaman dawn; cruise ship rebuilt as a clearly stacked liner." />
  </head>
  <body>
    <main class="h-screen w-screen overflow-hidden">
      <PalmTreeHero client:only="react" />
      <a
        href="/versions"
        class="fixed bottom-4 right-4 z-10 rounded-md border border-black/10 bg-white/90 px-3 py-1.5 text-xs font-medium text-neutral-600 no-underline backdrop-blur-sm transition-colors hover:text-neutral-900"
        >← All versions</a
      >
    </main>
    <style is:global>
      html, body { margin: 0; padding: 0; background: #fbfcfd; }
    </style>
  </body>
</html>
