---
// Shared versions index — the navigation menu listing every iteration.
// Rendered by BOTH the home page (/) and /versions so the menu lives in one
// place. Add new versions here only.
import '../styles/global.css';

const versions = [
  { href: '/original', label: 'Voxel — original', note: 'Chunky Minecraft-style blocks (1ba569a)' },
  { href: '/v1', label: 'Voxel v1 — smaller nodes', note: '1ba569a with halved vertex node dots' },
  { href: '/v2', label: 'Voxel v2 — stable nodes', note: 'No hotspot dots; flicker/doubling fixed' },
  { href: '/v3', label: 'Voxel v3 — island base (slabs)', note: 'First base attempt — flat slabs (superseded)' },
  { href: '/v4', label: 'Voxel v4 — rounded island', note: 'Rounded voxel beach islet with earthy underside' },
  { href: '/v5', label: 'Voxel v5 — water', note: 'Translucent turquoise sea + wet-sand shore around the islet' },
  { href: '/v6', label: 'Voxel v6 — sunrise', note: 'Soft dawn backdrop + warm raking light' },
  { href: '/v7', label: 'Voxel v7 — water ripple', note: 'Gentle animated lapping on the sea' },
  { href: '/v8', label: 'Voxel v8 — build-in', note: 'Palm self-assembles (points to edges to faces), then rotates' },
  { href: '/v9', label: 'Voxel v9 — full-scene build', note: 'Whole world draws in blue wireframe, settles to thin white edges' },
  { href: '/v10', label: 'Voxel v10 — hero section', note: 'Two-column hero: headline + CTA + 6 services that light up their palm node' },
  { href: '/v11', label: 'Voxel v11 — full-bleed hero', note: 'Scene as full-bleed background; text left, services right, palm centred' },
  { href: '/v12', label: 'Voxel v12 — interactive service map', note: 'Palm nodes pulse; click one to expand its service detail, others recede' },
  { href: '/v13', label: 'Voxel v13 — blueprint service map', note: 'Pinging points + holographic cards; connector line + traced detail panel' },
  { href: '/v14', label: 'Voxel v14 — longtail boat + mobile fit', note: 'Clean v9 scene + a small voxel longtail boat; camera pulls back on mobile' },
  { href: '/v15', label: 'Voxel v15 — karst pitons (in water)', note: 'Two limestone stacks in the islet water — too small/close (superseded by v16)' },
  { href: '/v16', label: 'Voxel v16 — horizon pitons (faded)', note: 'Hazy distant stacks — read as clouds, abandoned' },
  { href: '/v17', label: 'Voxel v17 — karst pitons back-right', note: 'The solid v15 rocks, repositioned further back-right behind the islet' },
  { href: '/v18', label: 'Voxel v18 — karst pitons deeper', note: 'Pushed deeper but drifted too far right (superseded by v19)' },
  { href: '/v19', label: 'Voxel v19 — karst pitons on the horizon', note: 'Same solid rocks pushed deep along the view axis — distant, centred-right' },
  { href: '/v20', label: 'Voxel v20 — sea receding to the pitons', note: 'Water extended back with shrinking cells; pitons emerge from distant sea' },
  { href: '/v21', label: 'Voxel v21 — round water disc', note: 'Sea reshaped into one clean circular pool containing islet, boat & pitons' },
  { href: '/v22', label: 'Voxel v22 — water depth perspective', note: 'v20 base + cells shrink toward the back and water darkens with depth' },
  { href: '/v23', label: 'Voxel v23 — rounded water back edge', note: 'v22 + the far water back edge curved into a circular arc (right-heavy)' },
  { href: '/v24', label: 'Voxel v24 — symmetric rounded back', note: 'Back arc centred on the view axis — curves evenly left + right on screen' },
  { href: '/v25', label: 'Voxel v25 — coconuts', note: 'Small cluster of voxel coconuts nestled under the palm crown (too small — abandoned)' },
  { href: '/v26', label: 'Voxel v26 — sun on the horizon', note: 'Warm voxel sun rising low center-left, balancing the pitons (maps to Growth)' },
  { href: '/v27', label: 'Voxel v27 — island reshaped back-left', note: 'Island pulled back off the boat at the front; grown into the empty back-left instead' },
  { href: '/blueprint', label: 'Blueprint — triangulated mesh', note: 'Low-poly translucent mesh palm' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Palmkit Studio — Versions</title>
    <meta name="description" content="Palmkit Studio — palm iterations index." />
  </head>
  <body>
    <main class="flex min-h-screen w-screen items-center justify-center bg-[#F4F7F6] px-6 py-10">
      <div class="w-full max-w-md">
        <p class="mb-1 text-xs font-medium uppercase tracking-wide text-[#15A89A]">Palmkit Studio</p>
        <h1 class="mb-6 text-lg font-semibold text-neutral-800">Palm versions</h1>
        <ul class="space-y-2">
          {
            versions.map((v) => (
              <li>
                <a
                  href={v.href}
                  class="block rounded-lg border border-black/10 bg-white px-4 py-3 no-underline shadow-sm transition-colors hover:border-[#15A89A]/50"
                >
                  <span class="block text-sm font-semibold text-neutral-800">{v.label}</span>
                  <span class="block text-xs text-neutral-500">{v.note}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </main>
    <style is:global>
      html,
      body {
        margin: 0;
        padding: 0;
        background: #f4f7f6;
      }
    </style>
  </body>
</html>
